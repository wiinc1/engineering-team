{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-js/master/packages/api/schema/stryker-schema.json",
  "testRunner": "command",
  "commandRunner": {
    "command": "node --test tests/unit/runtime-delegation.test.js tests/unit/specialist-delegation.test.js tests/unit/command-router-delegation.test.js tests/unit/validate-specialist-runtime.test.js tests/contract/specialist-delegation.contract.test.js tests/integration/specialist-delegation.integration.test.js tests/e2e/specialist-delegation.e2e.test.js tests/security/specialist-delegation.security.test.js"
  },
  "mutate": [
    "lib/software-factory/delegation.js",
    "lib/software-factory/runtime-delegation.js",
    "lib/software-factory/task-dispatch.js"
  ],
  "reporters": [
    "clear-text",
    "progress"
  ],
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 60
  }
}
