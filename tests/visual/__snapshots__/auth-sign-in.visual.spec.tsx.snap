// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`matches the configured enterprise OIDC state 1`] = `
<section
  aria-label="Sign-in screen"
  class="auth-card"
>
  <div
    class="auth-card__intro"
  >
    <p
      class="eyebrow"
    >
      Engineering Team
    </p>
    <h1>
      Sign in to Engineering Team
    </h1>
    <p
      class="lede"
    >
      Use the configured enterprise identity provider to access Engineering Team.
    </p>
  </div>
  <div
    class="session-form__actions"
  >
    <button
      type="button"
    >
      Continue with enterprise sign-in
    </button>
  </div>
</section>
`;

exports[`matches the local internal fallback state 1`] = `
<section
  aria-label="Sign-in screen"
  class="auth-card"
>
  <div
    class="auth-card__intro"
  >
    <p
      class="eyebrow"
    >
      Engineering Team
    </p>
    <h1>
      Sign in to Engineering Team
    </h1>
    <p
      class="lede"
    >
      Use the configured enterprise identity provider to access Engineering Team.
    </p>
  </div>
  <div
    class="session-form__actions"
  >
    <button
      disabled=""
      type="button"
    >
      Continue with enterprise sign-in
    </button>
  </div>
  <p
    class="auth-status auth-status--error"
    role="alert"
  >
    This deployment has no enabled sign-in method. Contact the production operator to restore the approved login path.
  </p>
  <form
    class="session-form auth-form"
  >
    <label>
      Trusted auth code
      <input
        name="authCode"
        placeholder="Paste the signed browser auth code"
        value=""
      />
    </label>
    <label>
      API base URL
      <input
        name="apiBaseUrl"
        placeholder="same-origin"
        value=""
      />
    </label>
    <div
      class="session-form__actions"
    >
      <button
        class="button-secondary"
        type="submit"
      >
        Use internal bootstrap fallback
      </button>
    </div>
  </form>
</section>
`;

