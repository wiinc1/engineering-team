{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "includeFiles": "db/migrations/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/tasks/:taskId/execution-contract/:action",
      "destination": "/api/v1/task-workflow-proxy?__workflow_path=tasks/:taskId/execution-contract/:action"
    },
    {
      "source": "/api/v1/tasks/:taskId/contract-coverage-audit/:action",
      "destination": "/api/v1/task-workflow-proxy?__workflow_path=tasks/:taskId/contract-coverage-audit/:action"
    },
    {
      "source": "/api/v1/tasks/:taskId/sre-monitoring/:action",
      "destination": "/api/v1/task-workflow-proxy?__workflow_path=tasks/:taskId/sre-monitoring/:action"
    },
    {
      "source": "/api/tasks/:taskId",
      "destination": "/api/v1/task-workflow-proxy?__audit_path=tasks/:taskId"
    },
    {
      "source": "/api/tasks/:taskId/:action(detail|history|observability-summary|state)",
      "destination": "/api/v1/task-workflow-proxy?__audit_path=tasks/:taskId/:action"
    },
    {
      "source": "/backend/v1/tasks/:taskId/execution-contract/:action",
      "destination": "/api/v1/task-workflow-proxy?__workflow_path=tasks/:taskId/execution-contract/:action"
    },
    {
      "source": "/backend/v1/tasks/:taskId/contract-coverage-audit/:action",
      "destination": "/api/v1/task-workflow-proxy?__workflow_path=tasks/:taskId/contract-coverage-audit/:action"
    },
    {
      "source": "/backend/v1/tasks/:taskId/sre-monitoring/:action",
      "destination": "/api/v1/task-workflow-proxy?__workflow_path=tasks/:taskId/sre-monitoring/:action"
    },
    {
      "source": "/backend/tasks/:taskId",
      "destination": "/api/v1/task-workflow-proxy?__audit_path=tasks/:taskId"
    },
    {
      "source": "/backend/tasks/:taskId/:action(detail|history|observability-summary|state)",
      "destination": "/api/v1/task-workflow-proxy?__audit_path=tasks/:taskId/:action"
    },
    {
      "source": "/backend",
      "destination": "/api"
    },
    {
      "source": "/backend/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "/api/auth/:path*"
    },
    {
      "source": "/:path((?!api/|backend/|assets/|favicon.ico|robots.txt).*)",
      "destination": "/index.html"
    }
  ]
}
