FROM node:22-bookworm-slim AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM node:22-bookworm-slim
WORKDIR /app
COPY --from=build /app/dist ./dist
COPY --from=build /app/scripts/serve-browser-dist.js ./scripts/serve-browser-dist.js
ENV PORT=4173
EXPOSE 4173
CMD ["node", "scripts/serve-browser-dist.js"]
