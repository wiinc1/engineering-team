# Example environment for durable factory-of-record services on this host.
# Generated runtime copy: observability/factory-stack/service.env (local, gitignored logs nearby).
# Managed by: npm run factory:stack:up

NODE_ENV=development
PORT=13000
DATABASE_URL=postgres://audit:audit@127.0.0.1:15432/engineering_team?sslmode=disable
PGSSLMODE=disable
AUDIT_STORE_BACKEND=postgres
AUTH_JWT_SECRET=golden-path-local-dev-secret
AUTH_SESSION_SECRET=golden-path-local-session-secret
AUTH_PRODUCTION_AUTH_STRATEGY=registration
AUTH_EMAIL_PROVIDER=test
AUTH_REGISTRATION_MODE=admin-approved
AUTH_REGISTRATION_DEFAULT_TENANT=engineering-team
AUTH_PUBLIC_APP_URL=http://127.0.0.1:15173
AUTH_REQUIRE_EMAIL_VERIFICATION=false
FF_AUDIT_FOUNDATION=true
FF_WORKFLOW_ENGINE=true
FF_EXECUTION_CONTRACTS=true
FF_PROJECTS=true
FF_INTAKE_DRAFT_CREATION=true
FF_REAL_SPECIALIST_DELEGATION=true
FACTORY_USE_FIXTURE_DELEGATION=false
FACTORY_PROOF_PROFILE=live
OPENCLAW_BASE_URL=http://127.0.0.1:18789
SPECIALIST_DELEGATION_RUNNER=node scripts/openclaw-specialist-runner.js
OPENCLAW_DELEGATION_TIMEOUT_SEC=90
OPENCLAW_DELEGATION_THINKING=low
FORGE_SERVICE_TOKEN=local-golden-path-forge-token
FORGEADAPTER_SERVICE_TOKEN=local-forgeadapter-token
TENANT_ID=engineering-team
ALLOW_LEGACY_HEADERS=false
