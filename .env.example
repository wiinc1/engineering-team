# Operator-hosted Postgres for the coordinated factory stack (not cloud Supabase).
# Local development default: Dockerized Postgres (see README / docs/runbooks/audit-foundation.md).
DATABASE_URL=postgres://audit:audit@127.0.0.1:5432/engineering_team

# Golden-path local stack often uses port 15432:
# DATABASE_URL=postgres://audit:audit@127.0.0.1:15432/engineering_team
# AUDIT_STORE_BACKEND=postgres

# File backend is fallback-only for isolated local dev/test harnesses.
AUDIT_STORE_BACKEND=postgres

# Runtime guards
NODE_ENV=development
FF_AUDIT_FOUNDATION=true
ALLOW_LEGACY_HEADERS=false
# Production auth strategy. Use "oidc" when an external IdP exists, or
# "magic-link" for first-party invite-only email auth when no production IdP exists.
# "internal-bootstrap" only when the explicit temporary production no-IdP strategy is approved.
AUTH_PRODUCTION_AUTH_STRATEGY=oidc
# Browser-visible production auth strategy. Set to "magic-link" for production
# magic-link builds unless runtime config injects productionAuthStrategy instead.
VITE_AUTH_PRODUCTION_AUTH_STRATEGY=oidc
# Name-only production gate evidence for deployments that inject
# window.__ENGINEERING_TEAM_RUNTIME_CONFIG__.productionAuthStrategy at runtime.
AUTH_BROWSER_RUNTIME_PRODUCTION_AUTH_STRATEGY=
AUTH_JWT_SECRET=replace-me
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_JWT_JWKS_URL=
# Local/internal-only server bootstrap fallback. Set false in production.
AUTH_ENABLE_INTERNAL_BROWSER_BOOTSTRAP=true

# Workers / ops
PORT=3000
PROJECTION_BATCH_SIZE=100
OUTBOX_BATCH_SIZE=100
PROJECTION_INTERVAL_MS=5000
OUTBOX_INTERVAL_MS=5000
PUSHGATEWAY_URL=
OUTBOX_WEBHOOK_URL=

# Production audit workers (separate from operator-hosted stack API — GP-007)
ET_FORGE_DISPATCH_ENABLED=false
FORGEADAPTER_BASE_URL=
ENGINEERING_TEAM_BASE_URL=
FORGEADAPTER_SERVICE_TOKEN=
FORGE_SERVICE_TOKEN=
PROJECTION_CATCHUP_LAG_THRESHOLD_SECONDS=2
PROJECTION_CATCHUP_MAX_RETRIES=3
PROJECTION_CATCHUP_WAIT_MS=1500
GOLDEN_PATH_PROJECTION_FALLBACK=

# Milestone A — coordinated stack factory verification (defaults: golden-path local stack)
FACTORY_STACK_BASE_URL=http://127.0.0.1:13000
STAGING_BASE_URL=
STAGING_OPERATOR_URL=
STAGING_AUTH_JWT_SECRET=
STAGING_GITHUB_WEBHOOK_SECRET=
STAGING_FORGEADAPTER_BASE_URL=
STAGING_EVIDENCE_DIR=observability/milestone-a-staging
STAGING_SKIP_FORGE_PHASES=true
FACTORY_STAGING_BASE_URL=

# GitHub issue → intake normalizer (GP-002, default off)
FF_GITHUB_INTAKE_NORMALIZER=false
FF_GITHUB_INTAKE_PROJECT_BOOTSTRAP=false
GITHUB_INTAKE_OPT_IN_LABEL=factory-intake
GITHUB_INTAKE_DEFAULT_TENANT=engineering-team
GITHUB_INTAKE_REPO_TENANT_MAP=

# Browser task-detail runtime (#26)
# If blank, the browser app calls same-origin /tasks/* endpoints.
# For a single-project operator-hosted stack deployment that serves both the SPA and the API,
# set this to /backend so browser requests route through the operator-hosted stack function
# prefix without colliding with SPA routes like /tasks.
VITE_TASK_API_BASE_URL=
# Optional Vite dev-server proxy target, e.g. http://127.0.0.1:3000
VITE_TASK_API_PROXY_TARGET=
VITE_OIDC_DISCOVERY_URL=
VITE_OIDC_CLIENT_ID=
# Optional; defaults to <origin>/auth/callback when blank.
VITE_OIDC_REDIRECT_URI=
# Optional; defaults to "openid profile email".
VITE_OIDC_SCOPE=
# Optional; used for enterprise logout redirects.
VITE_OIDC_LOGOUT_URL=
VITE_OIDC_LOGOUT_REDIRECT_URI=

# Magic-link production auth
AUTH_SESSION_SECRET=
AUTH_EMAIL_PROVIDER=resend
RESEND_API_KEY=
AUTH_EMAIL_FROM=
AUTH_PUBLIC_APP_URL=https://app.example.com
AUTH_MAGIC_LINK_TTL_MINUTES=15
AUTH_SESSION_TTL_HOURS=8
# Local/internal-only browser bootstrap fallback. Set false in production browser builds.
VITE_AUTH_INTERNAL_BOOTSTRAP_ENABLED=true

# Escape hatch only for exceptional non-local environments.
# Leave false in normal operation.
ALLOW_FILE_AUDIT_BACKEND_IN_PRODUCTION=false
