  API[Projects HTTP wrapper]
  TaskAPI[Canonical task API]
  Service[task-platform withProjects]
  Store[(File JSON or Postgres)]
  Audit[(Audit events and metrics)]

  Browser --> Route
  Browser --> Workspace
  Route --> API
